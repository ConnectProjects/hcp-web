# Lead Finder — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — used ONLY by the seed script (server-side, never in the browser)
# Found in: Project Settings > API > Project API keys > service_role
SUPABASE_SERVICE_KEY=eyJ...
